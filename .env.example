# Copy to .env and fill in. Never commit .env.

# Gmail SMTP (create an App Password: Google Account > Security > 2-Step Verification > App passwords)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=
BRIEF_RECIPIENT=gautam.news9@gmail.com
# Set to true once credentials above are filled in
EMAIL_ENABLED=false

# Active ingestion window (24h clock, inclusive start / exclusive end)
ACTIVE_WINDOW_START=6
ACTIVE_WINDOW_END=21

# Google News edition
NEWS_RSS_URL=https://news.google.com/rss?hl=en-IN&gl=IN&ceid=IN:en
STORIES_PER_CYCLE=5

# X desk provider: twtapi = real tweets via api.twtapi.com (default),
# sim = simulated demo feed (never mixes with real data)
X_PROVIDER=twtapi

# TwtAPI key (dashboard -> API key). Refreshes are MANUAL-ONLY via the
# dashboard button; each refresh spends one Search call per column (~3 total)
# so a 300-call month allows roughly 100 refreshes.
TWT_API_KEY=
# Top-trust handles included in each column's search call
X_HANDLES_PER_COLUMN=20

# Simulated feed rate (only used when X_PROVIDER=sim)
SIM_TWEETS_PER_MIN=12
