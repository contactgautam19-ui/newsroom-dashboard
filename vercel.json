{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron/tick", "schedule": "0 * * * *" },
    { "path": "/api/cron/live", "schedule": "30 * * * *" }
  ]
}
